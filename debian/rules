#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_auto_build:
	cargo build --release --bin pebble-led

override_dh_auto_install:
	install -Dm755 target/release/pebble-led \
		debian/pebble-led/usr/bin/pebble-led
	install -Dm644 data/pebble-led.service \
		debian/pebble-led/usr/lib/systemd/user/pebble-led.service

override_dh_auto_test:
	: # tests require a live BlueZ/D-Bus session; run separately in CI

override_dh_auto_clean:
	cargo clean || true
