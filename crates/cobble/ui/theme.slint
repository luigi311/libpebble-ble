// Shared colour palette.

export global Palette {
    out property <color> bg:         #0f0f23;
    out property <color> surface:    #1a1a38;
    out property <color> header:     #141428;
    out property <color> accent:     #4a9eff;
    out property <color> text:       #e8e8f4;
    out property <color> muted:      #6a6a90;
    out property <color> green:      #4caf50;
    out property <color> orange:     #ff9800;
    out property <color> red:        #ef5350;
    out property <color> deep-sleep: #7c3aed;
}
